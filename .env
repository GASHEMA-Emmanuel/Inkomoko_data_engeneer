# =============================================================================
# Inkomoko Data Engineering Pipeline - Environment Configuration
# =============================================================================
# NOTE: For a real deployment, never commit this file. A .env.example is
#       provided for sharing. These local-dev credentials are intentionally
#       simple so the reviewer can run everything with one command.
# =============================================================================

# ----- PostgreSQL (OLTP) -----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=inkomoko
POSTGRES_PASSWORD=inkomoko_pwd
POSTGRES_DB=inkomoko

# ----- ClickHouse (OLAP) -----
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9000
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=clickhouse_pwd
CLICKHOUSE_DB=raw
CLICKHOUSE_ANALYTICS_DB=analytics

# ----- Public REST API source -----
# JSONPlaceholder is fully public; no API key / authentication required.
API_BASE_URL=https://jsonplaceholder.typicode.com
API_TIMEOUT_SECONDS=30
API_MAX_RETRIES=5

# ----- Airflow -----
AIRFLOW_UID=50000
AIRFLOW_IMAGE_NAME=apache/airflow:2.10.4
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW__CORE__FERNET_KEY=MfzKv2t0dOCpDYtmuVRwXuXn-NSqa6CTiyNv9fZd5eQ=
AIRFLOW__WEBSERVER__SECRET_KEY=ac74a6c04f7800ebc229ac3ee71f7e73
